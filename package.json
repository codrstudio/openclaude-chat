{
  "name": "@codrstudio/openclaude-chat",
  "version": "0.1.7",
  "description": "Rich chat UI component — HTTP+SSE counterpart to @codrstudio/openclaude-sdk. Shadcn-native (consumes host tokens).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && postcss src/styles.css -o dist/styles.css",
    "build:ts": "tsc",
    "build:css": "postcss src/styles.css -o dist/styles.css",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-scroll-area": "^1",
    "@radix-ui/react-separator": "^1",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "embla-carousel-react": "^8",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.400.0",
    "react-markdown": "^9",
    "recharts": "^2",
    "rehype-highlight": "^7",
    "remark-gfm": "^4",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cssnano": "^7.1.4",
    "postcss": "^8.5.9",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codrstudio/openclaude-chat.git"
  }
}
