{
  "name": "@codrstudio/openclaude-chat",
  "version": "0.5.1",
  "description": "Rich chat UI component — distributed as a shadcn registry (source-copy). HTTP+SSE counterpart to @codrstudio/openclaude-sdk.",
  "private": true,
  "type": "module",
  "files": [
    "src",
    "registry",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "registry:source": "node scripts/build-registry.mjs",
    "registry:build": "npm run registry:source && npx shadcn@latest build --output ./registry"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1",
    "@radix-ui/react-separator": "^1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.400.0",
    "mermaid": "^11.14.0",
    "react-markdown": "^9",
    "recharts": "^2",
    "rehype-highlight": "^7",
    "remark-gfm": "^4",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^3",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codrstudio/openclaude-chat.git"
  }
}
